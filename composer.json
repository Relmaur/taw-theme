{
    "name": "taw/theme",
    "description": "TAW Theme — Tailwind + Alpine + WordPress starter theme",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Marco Del Riego",
            "email": "marck94zac1@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "taw/core": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "TAW\\Blocks\\": "Blocks/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TAW\\Theme\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/Relmaur/taw-core"
        }
    ],
    "scripts": {
        "post-create-project-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "npm install --silent"
        ],
        "phpstan": "phpstan analyse --memory-limit=-1",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11",
        "szepeviktor/phpstan-wordpress": "^2.0"
    }
}
